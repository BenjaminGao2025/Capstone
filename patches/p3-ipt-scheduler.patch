@@ -327,6 +327,13 @@ class Scheduler:
             self._get_ordered_requests = self._get_opt_ordered_requests
             self._update_priority = self._update_opt_priority
             self.need_score = True
+        elif self.schedule_type.startswith("ipt"):
+            # internal-predictor mode: scores come from the worker at prefill
+            # completion (main-model hidden state + tiny head), no aux engine
+            self._schedule = self._general_schedule
+            self._get_ordered_requests = self._get_ipt_ordered_requests
+            self._update_priority = self._update_opt_priority
+            self.need_score = False
         else:
             assert False, f"Not Supported Schedule Type {self.schedule_type}"
 
@@ -1002,6 +1009,33 @@ class Scheduler:
     def _update_opt_priority(self):
         pass
 
+    def _get_ipt_ordered_requests(self):
+        # v2 policy. v1 ("unscored first") let every new arrival preempt
+        # running work; on long-sequence traces (ShareGPT) the resulting
+        # preemption churn exhausted the CPU swap pool and killed the engine.
+        # v2 tiers:
+        #   0  starvation valve: unscored waiting > IPT_STARVE_S (default 30s)
+        #   1  RUNNING scored, shortest-predicted-first  (never preempted by
+        #      new arrivals -> bounded churn)
+        #   2  unscored, FCFS: admitted only into leftover budget
+        #   3  scored but not running (swapped/preempted), by score
+        starve_s = float(os.environ.get("IPT_STARVE_S", "30"))
+        now = time.time()
+        running_ids = set(id(r) for r in self.running)
+
+        def _key(req):
+            scored = req.aux_model_score is not None
+            if not scored and now - req.metrics.arrival_time > starve_s:
+                return (0, req.metrics.arrival_time, 0.0)
+            if scored and id(req) in running_ids:
+                return (1, 0.0, -req.aux_model_score)
+            if not scored:
+                return (2, req.metrics.arrival_time, 0.0)
+            return (3, 0.0, -req.aux_model_score)
+        return list(sorted(
+            list(self.waiting) + list(self.running) + list(self.swapped),
+            key=_key))
+
     def _get_ropt_ordered_requests(self):
 
         need_aux_scores = []
